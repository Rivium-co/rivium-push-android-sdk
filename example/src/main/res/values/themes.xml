<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.RiviumPushExample" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary</item>

        <!-- Tertiary (for TonalButton) -->
        <item name="colorTertiary">@color/primary</item>
        <item name="colorTertiaryContainer">#E8DEF8</item>
        <item name="colorOnTertiaryContainer">#1D192B</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_variant</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">#E7E0EC</item>
        <item name="colorOnSurfaceVariant">#49454F</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
    </style>

    <style name="Theme.RiviumPushExample.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>
